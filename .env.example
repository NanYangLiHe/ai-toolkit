# Configuration file for AI Toolkit
# Copy this to .env and fill in your settings

# Local LLM API endpoint (OpenAI-compatible format)
LLM_API_URL=http://localhost:1234/v1/chat/completions

# Model name (optional, depends on your server)
MODEL_NAME=local-model

# Default language for content generation
DEFAULT_LANG=en-US

# Temperature settings (0.0-1.0)
TEMPERATURE_GENERATION=0.7
TEMPERATURE_TRANSLATION=0.3
TEMPERATURE_CODE_REVIEW=0.3

# Output directory
OUTPUT_DIR=./output